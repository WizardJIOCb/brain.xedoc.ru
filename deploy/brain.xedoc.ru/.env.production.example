NODE_ENV=production
LOG_LEVEL=info
LOG_FORMAT=json

BRAIN_HOST_PORT=3031

SURREALDB_PASSWORD=change-me
SURREALDB_SCOPED_PASS=change-me
SURREALDB_POOL_SIZE=8
SURREALDB_SCOPED_POOL_SIZE=8

# Required by current boot validation. With EMBEDDER_PROVIDER=bge-m3, embeddings
# run locally; LLM-backed endpoints still need a real OpenAI key.
OPENAI_API_KEY=sk-change-me
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=3
OPENAI_CONCURRENCY=4

EMBEDDER_PROVIDER=bge-m3
EMBEDDING_CACHE_SIZE=2000

BRAIN_API_KEYS=[{"keyHash":"sha256:change-me","companyId":"co_xedoc","scopes":["brain:read","brain:write"]}]
FORGET_HMAC_KEY=change-me-at-least-32-chars

SEARCH_RERANKER_ENABLED=0
SEARCH_PREDICATE_ROUTER_ENABLED=0
SEARCH_HYPE_ENABLED=0
SEARCH_PPR_ENABLED=0
SEARCH_PPR_AUTO_THRESHOLD=0
COMPACTION_HOT_RETENTION_DAYS=90
COMPACTION_SUMMARIES=false

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
THROTTLE_EXPENSIVE_TTL_MS=60000
THROTTLE_EXPENSIVE_LIMIT=10
SYNTHESIZE_MIN_CONFIDENCE=0.30
OTEL_ENABLED=0
EXTRACTOR_SC_PASSES=1
